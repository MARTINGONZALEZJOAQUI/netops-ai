# Token del bot de Telegram (BotFather). NO subir el real al repositorio.
TELEGRAM_BOT_TOKEN=
# IDs de usuario de Telegram autorizados, separados por coma.
TELEGRAM_ALLOWED_USERS=
# Canal o chat por defecto donde el agente publica alertas.
TELEGRAM_HOME_CHANNEL=
# API key de NVIDIA NIM (prefijo nvapi-). NO subir la real al repositorio.
OPENAI_API_KEY=
# Limite de tokens de salida del modelo.
HERMES_MAX_TOKENS=8192
